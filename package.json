{
  "name": "@looppilot/cli",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "description": "Agent-native loop qualification pack for Codex and Claude Code.",
  "bin": {
    "looppilot": "scripts/looppilot.mjs"
  },
  "scripts": {
    "doctor": "node scripts/looppilot.mjs doctor --target both",
    "install:project": "node scripts/looppilot.mjs install --target both --scope project",
    "validate:fixtures": "node scripts/validate-fixtures.mjs",
    "validate:wrappers": "node scripts/validate-wrappers.mjs",
    "test": "node scripts/validate-all.mjs",
    "validate:schema": "node scripts/validate-schema.mjs",
    "validate:wrapper-parity": "node scripts/validate-wrapper-parity.mjs",
    "validate:scan": "node scripts/validate-scan-summary.mjs",
    "validate:exports": "node scripts/validate-exports.mjs",
    "scan": "node .looppilot/scripts/scan-summary.mjs",
    "report:coverage": "node scripts/report-fixture-coverage.mjs",
    "validate:export-command": "node scripts/validate-export-command.mjs",
    "validate:save-commands": "node scripts/validate-save-commands.mjs",
    "validate:install-command": "node scripts/validate-install-command.mjs",
    "validate:scan-security": "node scripts/validate-scan-security.mjs",
    "prepublishOnly": "npm test"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/looppilot/looppilot.git"
  },
  "files": [
    ".agents/skills/looppilot/SKILL.md",
    ".claude/commands/should-loop.md",
    ".claude/skills/looppilot/SKILL.md",
    ".looppilot/core/",
    ".looppilot/fixtures/",
    ".looppilot/scripts/scan-summary.mjs",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
